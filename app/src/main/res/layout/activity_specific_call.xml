<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chamado"
            android:textSize="14sp"
            android:textColor="@color/body_text_grey"/>

        <TextView
            android:id="@+id/txtNumeroChamado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#0001"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/deep_text_blue"
            android:layout_marginBottom="20dp"/>

        <!-- CARD PRINCIPAL -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/base_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- STATUS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/deep_text_blue"
                    android:layout_marginBottom="10dp"/>

                <RadioGroup
                    android:id="@+id/radioStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radioAberto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Em aberto"/>

                    <RadioButton
                        android:id="@+id/radioAndamento"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Em andamento"/>

                    <RadioButton
                        android:id="@+id/radioFinalizada"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Finalizada"/>
                </RadioGroup>

                <!-- SOLUÇÃO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solução"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/deep_text_blue"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Descreva a solução"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputSolucao"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:gravity="top"
                        android:inputType="textMultiLine"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- BOTÃO ENVIAR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEnviar"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="24dp"
                    android:text="Salvar alterações"
                    android:textColor="@color/base_white"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/tech_trust_blue"
                    app:cornerRadius="16dp"/>

                <!-- BOTÃO VOLTAR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVoltar"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginTop="14dp"
                    android:text="Voltar"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:textColor="@color/deep_text_blue"
                    app:backgroundTint="@color/base_white"
                    app:strokeColor="@color/border_grey"
                    app:strokeWidth="1.2dp"
                    app:cornerRadius="12dp"
                    android:layout_gravity="center"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>