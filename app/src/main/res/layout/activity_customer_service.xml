<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_light"
    android:paddingHorizontal="20dp"
    android:paddingTop="24dp"
    android:paddingBottom="12dp">

    <!-- HEADER -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Atendimento"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/deep_text_blue"
        android:layout_marginBottom="16dp"/>

    <!-- CARD DE RESUMO -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/base_white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chamados abertos"
                android:textSize="14sp"
                android:textColor="@color/body_text_grey"/>

            <TextView
                android:id="@+id/txtQtdChamados"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/tech_trust_blue"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- BUSCA -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Buscar chamados abertos"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusBottomEnd="14dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputBusca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- SEPARADOR -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="14dp"
        android:background="@color/border_grey"/>

    <!-- LISTA DE CHAMADOS ABERTOS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerChamadosAbertos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"/>

    <!-- BOTÃO VOLTAR -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVoltar"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:text="Voltar"
        android:textSize="12sp"
        android:textAllCaps="false"
        android:textColor="@color/deep_text_blue"
        app:backgroundTint="@color/base_white"
        app:strokeColor="@color/border_grey"
        app:strokeWidth="1.2dp"
        app:cornerRadius="12dp"
        android:layout_gravity="center"
        android:layout_marginTop="6dp"/>

</LinearLayout>