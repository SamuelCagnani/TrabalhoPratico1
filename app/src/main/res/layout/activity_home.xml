<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_light"
    android:paddingHorizontal="28dp"
    android:paddingTop="140dp"
    android:paddingBottom="16dp">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resolva Já"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:textColor="@color/tech_trust_blue"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Soluções rápidas na palma da sua mão"
            android:textSize="16sp"
            android:textColor="@color/body_text_grey"
            android:layout_marginTop="8dp"/>

    </LinearLayout>


    <!-- CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/base_white"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="O que você deseja fazer?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/deep_text_blue"
                android:layout_marginBottom="24dp"
                android:layout_gravity="center_horizontal"/>

            <!-- BOTÕES -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDemanda"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp"
                android:text="Cadastrar Demanda"
                android:textAllCaps="false"
                android:textColor="@color/base_white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/tech_trust_blue"
                app:cornerRadius="20dp"
                app:icon="@android:drawable/ic_input_add"
                app:iconGravity="textStart"
                app:iconPadding="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChamados"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp"
                android:text="Listar Chamados"
                android:textAllCaps="false"
                android:textColor="@color/base_white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/connect_blue"
                app:cornerRadius="20dp"
                app:icon="@android:drawable/ic_menu_sort_by_size"
                app:iconGravity="textStart"
                app:iconPadding="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAtendimentos"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Atendimentos"
                android:textAllCaps="false"
                android:textColor="@color/base_white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/success_green"
                app:cornerRadius="20dp"
                app:icon="@android:drawable/ic_menu_agenda"
                app:iconGravity="textStart"
                app:iconPadding="12dp"/>

            <!-- BOTÃO VOLTAR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVoltar"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Sair"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textColor="@color/urgency_red"
                app:backgroundTint="@color/base_white"
                app:strokeColor="@color/border_grey"
                app:strokeWidth="1.5dp"
                app:cornerRadius="14dp"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ESPAÇO -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- RODAPÉ -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="© Resolva Já"
        android:textSize="12sp"
        android:textColor="@color/body_text_grey"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

</LinearLayout>