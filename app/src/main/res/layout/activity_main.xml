<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/base_white">

    <!-- Logo -->
    <ImageView
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:contentDescription="Logo do app"
        android:scaleType="fitCenter"
        android:src="@drawable/resolva_ja" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bem-vindo ao Resolva Já"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/tech_trust_blue"
        android:layout_marginTop="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sua plataforma de suporte rápido"
        android:textSize="14sp"
        android:textColor="@color/body_text_grey"
        android:layout_marginBottom="32dp"/>

    <!-- Botão MODERNO -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/entrar"
        android:layout_width="260dp"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:text="Entrar"
        android:textAllCaps="false"
        android:textColor="@color/base_white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@color/tech_trust_blue"
        app:cornerRadius="18dp"
        app:elevation="4dp" />

</LinearLayout>