<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_light"
    android:paddingHorizontal="20dp"
    android:paddingTop="24dp"
    android:paddingBottom="12dp">

    <!-- HEADER -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Meus Chamados"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="-0.02"
        android:textColor="@color/tech_trust_blue"
        android:layout_marginBottom="24dp"/>

    <!-- BUSCA -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="@color/border_grey"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Pesquisar por título ou ID"
            app:boxBackgroundMode="none"
            app:hintEnabled="false"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:startIconTint="@color/body_text_grey"
            app:endIconMode="clear_text">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputBusca"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Pesquisar por título ou ID"
                android:background="@android:color/transparent"
                android:paddingVertical="16dp"
                android:textSize="16sp"
                android:textColor="@color/deep_text_blue"/>
        </com.google.android.material.textfield.TextInputLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- FILTROS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <!-- DATA -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnData"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:text="Filtrar Data"
            android:textSize="14sp"
            android:textColor="@color/deep_text_blue"
            android:textAllCaps="false"
            app:strokeColor="@color/border_grey"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_today"
            app:iconSize="18dp"
            app:iconTint="@color/tech_trust_blue"/>

        <View
            android:layout_width="12dp"
            android:layout_height="1dp"/>

        <!-- STATUS -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStatus"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:text="Filtrar Status"
            android:textSize="14sp"
            android:textColor="@color/deep_text_blue"
            android:textAllCaps="false"
            app:strokeColor="@color/border_grey"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_info_details"
            app:iconSize="18dp"
            app:iconTint="@color/tech_trust_blue"/>

    </LinearLayout>

    <!-- LISTA -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerChamados"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="80dp"/>

    <!-- BOTÃO VOLTAR -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVoltar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Voltar ao Início"
        android:textSize="15sp"
        android:textAllCaps="false"
        android:textColor="@color/body_text_grey"
        app:backgroundTint="@color/surface_light"
        app:strokeColor="@color/border_grey"
        app:strokeWidth="1dp"
        app:cornerRadius="20dp"
        android:layout_marginTop="8dp"/>

</LinearLayout>