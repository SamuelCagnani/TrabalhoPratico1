<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/base_white"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/txtIdChamado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#001"
                android:textStyle="bold"
                android:textColor="@color/tech_trust_blue"
                android:textSize="13sp"
                android:letterSpacing="0.05"
                android:background="@color/surface_light"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/txtStatusChamado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Em aberto"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/button_outline"
                android:textColor="@color/tech_trust_blue"
                android:letterSpacing="0.1"/>
        </LinearLayout>

        <TextView
            android:id="@+id/txtTituloChamado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Título do Chamado"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textColor="@color/deep_text_blue"
            android:layout_marginBottom="6dp"
            android:lineSpacingExtra="2dp"/>

        <TextView
            android:id="@+id/txtLocalChamado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Local: Sala 102"
            android:textSize="15sp"
            android:textColor="@color/body_text_grey"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_grey"
            android:layout_marginVertical="16dp"/>

        <TextView
            android:id="@+id/txtDataChamado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="15/10/2023 14:30"
            android:textSize="12sp"
            android:textColor="@color/body_text_grey"
            android:gravity="end"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
