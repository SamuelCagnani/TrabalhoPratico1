<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Conteudo principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/tech_trust_blue"
            android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
            app:title="@string/app_name"
            app:navigationIcon="@drawable/ic_menu"
            app:titleTextColor="@color/base_white" />

        <!-- Area de conteudo (home padrao) -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/surface_light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:paddingTop="48dp"
                android:paddingBottom="16dp">

                <!-- HEADER -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="40dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resolva Já"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:textColor="@color/tech_trust_blue"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Soluções rápidas na palma da sua mão"
                        android:textSize="16sp"
                        android:textColor="@color/body_text_grey"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

                <!-- CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="12dp"
                    app:cardBackgroundColor="@color/base_white"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="O que você deseja fazer?"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/deep_text_blue"
                            android:layout_marginBottom="24dp"
                            android:layout_gravity="center_horizontal"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDemanda"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:layout_marginBottom="16dp"
                            android:text="Cadastrar Demanda"
                            android:textAllCaps="false"
                            android:textColor="@color/base_white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/tech_trust_blue"
                            app:cornerRadius="20dp"
                            app:icon="@android:drawable/ic_input_add"
                            app:iconGravity="textStart"
                            app:iconPadding="12dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnChamados"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:layout_marginBottom="16dp"
                            android:text="Listar Chamados"
                            android:textAllCaps="false"
                            android:textColor="@color/base_white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/connect_blue"
                            app:cornerRadius="20dp"
                            app:icon="@android:drawable/ic_menu_sort_by_size"
                            app:iconGravity="textStart"
                            app:iconPadding="12dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAtendimentos"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:text="Atendimentos"
                            android:textAllCaps="false"
                            android:textColor="@color/base_white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/success_green"
                            app:cornerRadius="20dp"
                            app:icon="@android:drawable/ic_menu_agenda"
                            app:iconGravity="textStart"
                            app:iconPadding="12dp"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ESPACO -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <!-- RODAPE -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="© Resolva Já"
                    android:textSize="12sp"
                    android:textColor="@color/body_text_grey"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"/>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- Menu lateral -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/drawer_header"
        app:menu="@menu/drawer_menu"
        app:itemTextColor="@color/deep_text_blue"
        app:itemIconTint="@color/tech_trust_blue"
        app:itemTextAppearance="@style/NavItemText" />

</androidx.drawerlayout.widget.DrawerLayout>
